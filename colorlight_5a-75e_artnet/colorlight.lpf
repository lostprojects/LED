IOBUF PORT "hub75_b1[4]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[5]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[6]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[7]" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_b1[8]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[9]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[10]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[11]" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_b1[12]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[13]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[14]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_b1[15]" IO_TYPE=LVCMOS33;

