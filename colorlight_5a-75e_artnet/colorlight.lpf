IOBUF PORT "hub75_g1[12]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_g1[13]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_g1[14]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_g1[15]" IO_TYPE=LVCMOS33;

# HUB75 Output Group - B1 pins (J1 to J16)
LOCATE COMP "hub75_b1[0]" SITE "E4";      # J1
LOCATE COMP "hub75_b1[1]" SITE "G3";      # J2
