# Global Timing Constraints for Asynchronous Domains
BLOCK RESETPATHS;
BLOCK ASYNCPATHS;

BLOCK PATH FROM CLKNET "eth_rx_clk" TO CLKNET "clk_125m";
BLOCK PATH FROM CLKNET "clk_125m" TO CLKNET "eth_rx_clk";
BLOCK PATH FROM CLKNET "clk_25m" TO CLKNET "clk_125m";
