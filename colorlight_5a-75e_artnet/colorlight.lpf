IOBUF PORT "hub75_r1[0]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[1]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[2]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_r1[4]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[5]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[6]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[7]" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_r1[8]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[9]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[10]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[11]" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_r1[12]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[13]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[14]" IO_TYPE=LVCMOS33; IOBUF PORT "hub75_r1[15]" IO_TYPE=LVCMOS33;

# HUB75 Output Group - G1 pins (J1 to J16)
LOCATE COMP "hub75_g1[0]" SITE "D4";      # J1
LOCATE COMP "hub75_g1[1]" SITE "F5";      # J2
LOCATE COMP "hub75_g1[2]" SITE "H5";      # J3
