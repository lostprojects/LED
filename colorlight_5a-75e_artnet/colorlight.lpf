# MDIO / MDC interface
LOCATE COMP "mdio" SITE "T4";
IOBUF PORT "mdio" IO_TYPE=LVCMOS33;

LOCATE COMP "mdc" SITE "R5";
IOBUF PORT "mdc" IO_TYPE=LVCMOS33;
