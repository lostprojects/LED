# ==============================================================================
# Colorlight 5A-75E 16-Port Master Constraint File (.lpf)
# ==============================================================================

# Clock & Board Controls
LOCATE COMP "clk_25m" SITE "P6";          # 25MHz Oscillator
IOBUF PORT "clk_25m" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk_25m" 25.0 MHz;

LOCATE COMP "led_pin" SITE "T6";          # Status LED (active low)
IOBUF PORT "led_pin" IO_TYPE=LVCMOS33;

LOCATE COMP "btn_n" SITE "R7";            # Button (active low)
IOBUF PORT "btn_n" IO_TYPE=LVCMOS33 PULLMODE=UP;

# Ethernet RGMII PHY 0 Pins (Port 1 on the board)
LOCATE COMP "eth_rx_clk" SITE "J1";      # RXC
LOCATE COMP "eth_rx_ctrl" SITE "J2";     # RXCTL
LOCATE COMP "eth_rxd[0]" SITE "K2";      # RXD0
LOCATE COMP "eth_rxd[1]" SITE "J3";      # RXD1
LOCATE COMP "eth_rxd[2]" SITE "K1";      # RXD2
LOCATE COMP "eth_rxd[3]" SITE "K3";      # RXD3
IOBUF PORT "eth_rx_clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "eth_rx_clk" 125.0 MHz;
IOBUF PORT "eth_rx_ctrl" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_rxd[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_rxd[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_rxd[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_rxd[3]" IO_TYPE=LVCMOS33;

LOCATE COMP "eth_tx_clk" SITE "L1";      # TXC
LOCATE COMP "eth_txd[0]" SITE "M2";      # TXD0
LOCATE COMP "eth_txd[1]" SITE "M1";      # TXD1
LOCATE COMP "eth_txd[2]" SITE "P1";      # TXD2
LOCATE COMP "eth_txd[3]" SITE "R1";      # TXD3
LOCATE COMP "eth_tx_ctrl" SITE "L2";     # TXCTL
IOBUF PORT "eth_tx_clk" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_txd[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_txd[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_txd[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_txd[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth_tx_ctrl" IO_TYPE=LVCMOS33;

# Shared PHY Management & Reset Control
LOCATE COMP "eth_rst_n" SITE "R6";        # PHYRST#
IOBUF PORT "eth_rst_n" IO_TYPE=LVCMOS33;

# Shared HUB75 Row Address & Clock Controls
LOCATE COMP "hub75_a" SITE "N5";          # A
LOCATE COMP "hub75_b" SITE "N3";          # B
LOCATE COMP "hub75_c" SITE "P3";          # C
LOCATE COMP "hub75_d" SITE "P4";          # D
LOCATE COMP "hub75_e" SITE "N4";          # E
LOCATE COMP "hub75_clk" SITE "M3";        # CLK
LOCATE COMP "hub75_lat" SITE "N1";        # STB (Latch)
LOCATE COMP "hub75_oe" SITE "M4";         # OE

IOBUF PORT "hub75_a" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_b" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_c" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_d" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_e" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_clk" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_lat" IO_TYPE=LVCMOS33;
IOBUF PORT "hub75_oe" IO_TYPE=LVCMOS33;

# HUB75 Output Group - R1 pins (J1 to J16)
LOCATE COMP "hub75_r1[0]" SITE "C4";      # J1
LOCATE COMP "hub75_r1[1]" SITE "F3";      # J2
LOCATE COMP "hub75_r1[2]" SITE "G5";      # J3
